  "comb_active_avg_tax": "AVG(employees[].salary~isActive == true) * 0.1",
  "comb_max_salary_hr_it": "MAX(employees[].salary~department IN ('IT', 'HR'))",
  "comb_count_non_it_rich": "COUNT(employees[].id~department != 'IT' && salary >= 9000000)",
  "prec_math_1": "10 + 5 * 2",
