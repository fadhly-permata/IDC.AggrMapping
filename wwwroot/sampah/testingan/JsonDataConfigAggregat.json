  "order_salary_asc": "employees[].name~~salary ASC",
  "order_name_desc": "employees[].name~~name DESC",
  "order_date_desc": "employees[].name~~joinDate DESC",
  "order_multi_index": "employees[].name[0,2]~~salary DESC",
