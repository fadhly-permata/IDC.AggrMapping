{
  "aggr_sum_multi_order": "sum(employees[].salary~~address.negara ASC, address.kota DESC)",
  "aggr_sum": "sum(employees[].salary)",
  "aggr_avg": "AVG(employees[].salary)",
  "aggr_min": "MIN(employees[].bonus)",
  "aggr_max": "MAX(departments[].budget)",
  "aggr_count_hr": "COUNT(employees[].id~department == 'HR')",
  "arith_add": "employees[].salary[0] + 500000",
  "arith_sub": "departments[].budget[0] - SUM(employees[].salary~department == 'IT')",
  "arith_mul": "employees[].salary[3] * 1.15",
  "arith_div": "SUM(employees[].salary) / COUNT(employees[].id)",
