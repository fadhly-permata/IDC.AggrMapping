  "real_prec_daily_rate": "val(employees[].bonus[0]) + val(employees[].salary[0]) / 22",
  "paren_math_1": "(10 + 5) * 2",
  "paren_math_2": "100 / (5 + 15)",
  "paren_math_3": "(50 - 10) * (4 + 2)",
  "paren_math_4": "((10 + 2) * 3) / 4",
  "paren_math_5": "1000 / (2 * (2 + 3))",
  "real_paren_avg_income_hr": "(SUM(employees[].salary~department == 'HR') + SUM(employees[].bonus~department == 'HR')) / COUNT(employees[].id~department == 'HR')",
  "real_paren_bonus_sharing": "(departments[].budget[0] - SUM(employees[].salary~department == 'IT')) / COUNT(employees[].id)",
  "real_paren_bonus_achievement": "(val(employees[].bonus[3]) / (val(employees[].salary[3]) * 0.3)) * 100",
